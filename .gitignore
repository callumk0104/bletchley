# --- Dependencies ---
/node_modules

# --- Frontend build output (Vite) ---
/dist
/dist-ssr
*.local

# --- Tauri / Rust build artifacts (large, regenerated) ---
/src-tauri/target
/src-tauri/gen

# --- Updater signing keys: NEVER commit these ---
*.key
*.key.pub
*.pem
.tauri/

# --- Local SQLite data (the real DB lives in your OS app-data dir, not the repo) ---
*.db
*.db-shm
*.db-wal
*.sqlite

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp

# --- OS noise ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Local updater testing (gitignored: never ship the localhost endpoint) ---
/src-tauri/tauri.update-test.json
/update-test/
